# =============================================================================
# Copy to `.env` in the repo root. Never commit `.env`.
# Set JWT_SECRET for the API and MCP Bearer auth.
# Set SKIP_DOTENV=1 (and export JWT_SECRET, admin vars) to ignore `.env` in CI.
# =============================================================================

# --- Required ---
#JWT_SECRET=

# --- Optional JWT / auth tuning ---
# ALGORITHM=HS256
# JWT_ISSUER=http://127.0.0.1:8000
# JWT_AUDIENCE=
# ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- MCP OAuth metadata (WWW-Authenticate / resource URLs) ---
# PUBLIC_BASE_URL=http://127.0.0.1:8000

# --- User store ---
# USER_STORE=static
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD_HASH=$2b$12$...
# ADMIN_PASSWORD=

# --- Future: async SQLAlchemy (see server/adapters/persistence/database.py) ---
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/dbname

# --- Weather tool ---
# WEATHER_API_KEY=

# --- Test agent / Streamlit (optional) ---
# MCP_SERVER_URL=http://127.0.0.1:8000
# MCP_BEARER_TOKEN=
# MCP_AUTH_USERNAME=
# MCP_AUTH_PASSWORD=
# GROQ_API_KEY=
